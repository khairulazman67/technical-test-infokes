{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "start:prod": "bun run dist/index.js",
    "test": "NODE_ENV=test ./node_modules/.bin/jest",
    "test:watch": "NODE_ENV=test ./node_modules/.bin/jest --watch",
    "test:coverage": "NODE_ENV=test ./node_modules/.bin/jest --coverage",
    "db:generate": "./node_modules/.bin/prisma generate",
    "db:push": "./node_modules/.bin/prisma db push",
    "db:migrate": "./node_modules/.bin/prisma migrate dev",
    "db:seed": "bun prisma/seed.ts",
    "db:studio": "./node_modules/.bin/prisma studio"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/client": "^6.0.0",
    "@repo/types": "workspace:*",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.26",
    "prisma": "^6.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
